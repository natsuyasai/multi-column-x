{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "column-webview",
  "description": "Capability for column webviews",
  "windows": ["column-*"],
  "permissions": [
    "core:default",
    "core:webview:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://**" }, { "url": "http://**" }, { "url": "mailto://**" }]
    }
  ]
}
