{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "column-webview",
  "description": "Capability for column webviews",
  "windows": ["column-*", "popup-*", "main"],
  "remote": {
    "urls": ["https://*", "http://*"]
  },
  "permissions": [
    "core:default",
    "core:webview:default",
    "opener:default",
    "opener:allow-default-urls"
  ]
}
