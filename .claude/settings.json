{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NonInteractive -File .claude/hooks/post-edit-format.ps1"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "現在のセッション状態をまとめた引き継ぎファイルを生成して。.claude/handoff/session-{timestamp}.json に保存して。"
          }
        ]
      }
    ]
  }
}
