{
  "name": "multi-column-x",
  "private": true,
  "version": "0.1.4",
  "type": "module",
  "scripts": {
    "build:inject": "vite build --config vite.inject.config.ts && vite build --config vite.inject.config.ts --mode react",
    "dev": "npm run build:inject && vite",
    "build": "npm run build:inject && tsc && vite build",
    "preview": "vite preview",
    "format": "npm run format:ts && npm run format:rust && npm run format:kotlin",
    "format:ts": "prettier --write .",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:kotlin": "cd src-tauri\\gen\\android && .\\gradlew.bat ktlintFormat",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "tauri": "tauri",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:property": "vitest run --project unit property.test",
    "test:story": "vitest run --project storybook",
    "tauri:dev": "npm run build:inject && tauri dev",
    "tauri:build": "npm run build:inject && tauri build",
    "tauri:build:debug": "tauri build --debug",
    "tauri:android:dev": "tauri android dev",
    "tauri:android:build": "tauri android build",
    "tauri:android:build:debug": "tauri android build --debug",
    "tauri:android:dev:clear-cache": "tauri android dev -- --clear-cache",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fast-check": "^4.8.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "sass-embedded": "^1.99.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.0.4",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.5",
    "storybook": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "eslint-plugin-storybook": "^10.4.6",
    "playwright": "^1.61.0",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5"
  }
}
