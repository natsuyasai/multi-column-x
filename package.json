{
  "name": "multi-column-x",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:inject": "vite build --config vite.inject.config.ts && vite build --config vite.inject.config.ts --mode react",
    "dev": "npm run build:inject && vite",
    "build": "npm run build:inject && tsc && vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri:dev": "npm run build:inject && tauri dev",
    "tauri:build": "npm run build:inject && tauri build",
    "tauri:build:debug": "tauri build --debug",
    "tauri:android:build": "tauri android build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-store": "^2.4.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "uuid": "^14.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "sass-embedded": "^1.99.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.5"
  }
}
